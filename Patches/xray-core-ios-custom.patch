+// embeddedTunFd stores fd + 1 so the zero value means "not provided".
+// iOS embedders use this direct path because process environment propagation
+// is not reliable enough during Network Extension startup.
+var embeddedTunFd atomic.Int64
+
+// SetTunFd supplies the Network Extension-owned packet fd to the next TUN
+// instance. The fd remains owned by the embedding application.
+func SetTunFd(fd int) {
+	embeddedTunFd.Store(int64(fd) + 1)
+}
+
 func NewTun(options TunOptions) (Tun, error) {
+	if encodedFd := embeddedTunFd.Load(); encodedFd > 0 {
+		fd := int(encodedFd - 1)
+		if err := unix.SetNonblock(fd, true); err != nil {
+			return nil, err
+		}
+
+		return &DarwinTun{
+			tunFile: os.NewFile(uintptr(fd), "utun"),
+			options: options,
+			ownsFd:  false,
+		}, nil
+	}
+
